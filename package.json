{
  "name": "mora-tictactoe",
  "version": "1.0.0",
  "description": "Un Tic-acToe minimaliste et néon",
  "main": "main.js",
  "author": "Imane Saber",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.mora-tictactoe",
    "productName": "Mora TicTacToe",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.png",
      "target": "portable"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb",
        "dir",
        "snap"
      ],
      "category": "Game"
}
  },
  "devDependencies": {}
}
