{
  "name": "tictactoe",
  "version": "1.0.0",
  "description": "Un Tic-Tac-Toe minimaliste et néon",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.tictactoe",
    "productName": "Tic-Tac-Toe",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "portable"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb",
        "snap"
      ],
      "category": "Game"
}
  },
  "devDependencies": {
    "electron": "^41.0.2"
  }
}
